NODE_ENV=development
PORT=4000

# Local development only — use MongoDB Atlas URI on Render/production
MONGO_URI=mongodb://localhost:27017/smart-leads

JWT_ACCESS_SECRET=change_me_use_a_long_random_secret_min_32_chars
JWT_ACCESS_TTL=15m
BCRYPT_SALT_ROUNDS=12
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# Optional: seed admin user (npm run seed)
ADMIN_NAME=Admin User
ADMIN_EMAIL=admin@smartleads.io
ADMIN_PASSWORD=ChangeMe123!
